rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios — solo el propio usuario puede leer/escribir
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Guías públicas — lectura abierta, escritura autenticada
    match /public_guides/{slug} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Config (prompt de Salma) — lectura abierta (worker sin auth), escritura abierta (worker REST)
    match /config/{doc} {
      allow read: if true;
      allow write: if true;
    }
    match /config/{doc}/history/{histId} {
      allow read: if true;
      allow write: if true;
    }

    // Admin logs — escritura abierta (worker), lectura autenticada
    match /admin_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
  }
}
